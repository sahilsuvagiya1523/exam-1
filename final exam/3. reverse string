#include <stdio.h>

    void reverse(char s[])
{
    int i, len=0;
    char t;
    
    while(s[len] !='\0')
       len++;
       
    for(i=0;i<len/2;i++)
    {
        t=s[i];
        s[i]=s[len-1-i];
        s[len-1-i]=t;
    }
}
    int main()
    {
        char s[20];
        scanf("%s",s);
        reverse(s);
        printf("%s",s);
        
        return 0;
    }        
    